{
  "name": "mcp-servers",
  "private": true,
  "version": "0.0.0",
  "description": "MCP servers wrapping Leadfeeder and Oneflow APIs",
  "type": "module",
  "packageManager": "pnpm@10.12.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "dev:leadfeeder": "pnpm --filter @mcp-servers/leadfeeder-mcp dev"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
