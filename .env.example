# ---- Transport -------------------------------------------------------------
# stdio (default, for local Claude Desktop) or http (for Azure/remote)
MCP_TRANSPORT=stdio

# Port for HTTP transport (Azure Container Apps default)
PORT=3000

# Bearer token required on the remote /mcp endpoint (HTTP transport only)
# Generate a long random string (e.g. `openssl rand -hex 32`)
MCP_AUTH_TOKEN=

# ---- Leadfeeder ------------------------------------------------------------
# Get from Leadfeeder: Personal settings -> API keys
# Used for the v1 API (X-Api-Key header)
LEADFEEDER_API_KEY=
# Legacy API uses Token auth with the same key: `Authorization: Token token=...`
# Leadfeeder recommends sending a User-Agent identifying your integration.
LEADFEEDER_USER_AGENT=mcp-servers/leadfeeder-mcp

# ---- Oneflow ---------------------------------------------------------------
# Get from Oneflow: Marketplace -> API tokens -> Generate new token
ONEFLOW_API_TOKEN=
# Optional: email of an active Oneflow user to scope permissions
ONEFLOW_USER_EMAIL=

# ---- Logging ---------------------------------------------------------------
# trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
